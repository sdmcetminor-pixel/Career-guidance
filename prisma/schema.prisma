// Prisma Schema for Career Guidance System
// Supports both PostgreSQL and SQLite (defaults to SQLite for easier setup)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Default to SQLite for easier setup. Change to "postgresql" for production
  url      = env("DATABASE_URL")
}

// User model with roles
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // Hashed password
  role      String   @default("STUDENT") // STUDENT, COUNSELOR, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assessments     Assessment[]
  recommendations Recommendation[]
  savedCareers    SavedCareer[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// Career/Job Profile model
model Career {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // e.g., "Technology", "Healthcare", "Finance"
  salaryRange String?  // e.g., "$50k - $100k"
  education   String?  // Required education level
  skills      String   // Comma-separated skills
  growth      String?    // Job growth outlook
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  savedCareers SavedCareer[]

  @@index([category])
  @@index([title])
  @@map("careers")
}

// Assessment/Test model
model Assessment {
  id          String   @id @default(cuid())
  title       String
  description String?
  questions   String   // JSON string of questions
  userId      String
  score       Int?     // Assessment score
  result      String?  // Assessment result/recommendation
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("assessments")
}

// Recommendation model
model Recommendation {
  id          String   @id @default(cuid())
  userId      String
  careerId    String?  // Recommended career
  title       String
  description String
  type        String   @default("CAREER") // CAREER, SKILL, EDUCATION, RESOURCE
  priority    Int      @default(1) // 1 = highest priority
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("recommendations")
}

// Saved Career model (user bookmarks)
model SavedCareer {
  id        String   @id @default(cuid())
  userId    String
  careerId  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@unique([userId, careerId])
  @@index([userId])
  @@index([careerId])
  @@map("saved_careers")
}
