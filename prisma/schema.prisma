generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////
// USER
/////////////////////////////////////////////////
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("STUDENT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessments     Assessment[]
  recommendations Recommendation[]
  savedCareers    SavedCareer[]

  @@map("users")
}

/////////////////////////////////////////////////
// CAREERS
/////////////////////////////////////////////////
model Career {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  salaryRange String?
  education   String?
  skills      String
  growth      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  savedCareers SavedCareer[]

  @@map("careers")
}

/////////////////////////////////////////////////
// ASSESSMENT (ONE TEST ATTEMPT)
/////////////////////////////////////////////////
model Assessment {
  id           String   @id @default(cuid())
  userId       String
  standard     String   // 10th, 12th, diploma, etc
  region       String   // north | south
  completed    Boolean  @default(false)
  timeExpired  Boolean  @default(false)
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers          AssessmentAnswer[]
  aptitudeScores   AptitudeScore[]
  profileScores    ProfileScore[]
  finalScore       FinalScore?

  @@map("assessments")
}

/////////////////////////////////////////////////
// RAW ANSWERS (SKIP SUPPORTED)
/////////////////////////////////////////////////
model AssessmentAnswer {
  id            String   @id @default(cuid())
  assessmentId  String
  questionId    String
  questionType  String   // aptitude | profile
  answerValue   Int?     // NULL = skipped
  createdAt     DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("assessment_answers")
}

/////////////////////////////////////////////////
// APTITUDE SCORES (SECTION WISE)
/////////////////////////////////////////////////
model AptitudeScore {
  id              String   @id @default(cuid())
  assessmentId    String
  section         String   // Numerical, Verbal, Logical
  correctCount    Int
  totalQuestions  Int
  percentage      Int
  createdAt       DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("aptitude_scores")
}

/////////////////////////////////////////////////
// PROFILE / RIASEC / OCEAN SCORES
/////////////////////////////////////////////////
model ProfileScore {
  id            String   @id @default(cuid())
  assessmentId  String
  factor        String   // R, I, A, S, E, C OR O, C, E, A, N
  averageScore  Float
  percentage    Float
  createdAt     DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("profile_scores")
}

/////////////////////////////////////////////////
// FINAL STREAM DECISION
/////////////////////////////////////////////////
model FinalScore {
  id               String   @id @default(cuid())
  assessmentId     String   @unique
  scienceFit       Float
  commerceFit      Float
  artsFit          Float
  recommendedStream String
  confidence       Int
  flexibility      Int
  createdAt        DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("final_scores")
}

/////////////////////////////////////////////////
// AI / SYSTEM RECOMMENDATIONS
/////////////////////////////////////////////////
model Recommendation {
  id          String   @id @default(cuid())
  userId      String
  assessmentId String?
  title       String
  description String
  type        String   @default("CAREER")
  priority    Int      @default(1)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

/////////////////////////////////////////////////
// SAVED CAREERS
/////////////////////////////////////////////////
model SavedCareer {
  id        String   @id @default(cuid())
  userId    String
  careerId  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@unique([userId, careerId])
  @@map("saved_careers")
}